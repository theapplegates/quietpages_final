    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "astro": "latest",
    "astro-cloudinary": "^1.3.5",
    "cloudinary": "^2.10.0",
    "tailwindcss": "^3.4.0",
    "esbuild": "^0.28.1",
    "fsevents": "^2.3.3",
    "node-addon-api": "^8.9.0",
    "node-gyp": "^12.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.1"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  },
  "devDependencies": {
      "prettier": "^3.8.4",
      "vite": "^6.0.0" 
