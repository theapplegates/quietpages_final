{
  "name": "quiet-pages",
  "version": "2.1.0",
  "description": "A quiet Astro magazine theme for essays, field notes, and long-form writing.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/prune-unused-assets.mjs",
    "preview": "astro preview",
    "cloudinary:breakpoints": "NODE_OPTIONS=--max-old-space-size=8192 node --env-file=.env scripts/cloudinary-breakpoints.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "astro-cloudinary": "^1.3.5",
    "cloudinary": "^2.10.0",
    "esbuild": "^0.28.1",
    "node-addon-api": "^8.9.0",
    "node-gyp": "^12.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  },
  "devDependencies": {
    "@astrojs/mdx": "^6.0.0",
    "@astrojs/react": "^5.0.7",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^6.4.4",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.0"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "sharp@0.34.5": true,
    "sharp@0.35.3": true,
    "node-addon-api@8.9.0": true,
    "node-gyp@12.4.0": true,
    "fsevents@2.3.3": true
  }
}
