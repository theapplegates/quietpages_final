  "description": "A quiet Astro magazine theme for essays, field notes, and long-form writing.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/prune-unused-assets.mjs",
